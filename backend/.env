# Port
PORT=5000

# Database
MONGO_URI=mongodb://127.0.0.1:27017/edunest
# یا برای MongoDB Atlas:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/edunest

# JWT Secret (حداقل 32 کاراکتر تصادفی)
JWT_SECRET=your_super_secret_key_change_this_in_production

# Email (برای ارسال ایمیل فراموشی رمز و اعلان‌ها)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_or_email_password

# Cloudinary (برای آپلود عکس و ویدیو)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stripe (درگاه پرداخت)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx   # از دشبورد استریپ بگیرید

# Frontend URL (برای CORS و redirect پس از پرداخت)
CLIENT_URL=http://localhost:3000

# (اختیاری) برای ارسال SMS (در صورت نیاز)
SMS_API_KEY=your_sms_api_key